# Base URL of the Laravel API (include /api suffix)
# Android emulator: http://10.0.2.2:8000/api
# iOS simulator / web: http://127.0.0.1:8000/api
# Render (build): set in dashboard when running `npm run export:web`, e.g.
# EXPO_PUBLIC_API_URL=https://your-api.onrender.com/api
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api
